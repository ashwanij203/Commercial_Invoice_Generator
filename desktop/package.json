{
  "name": "jaiswal-billing",
  "version": "1.0.0",
  "description": "Jaiswal Furniture & Electronics — Billing System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "postinstall": "npx -y electron-rebuild",
    "build-frontend": "cd ../frontend && npm run build",
    "pack": "electron-builder --win",
    "dist": "npm run build-frontend && node build.js && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.jaiswal.billing",
    "productName": "Jaiswal Billing",
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "renderer",
        "to": "renderer",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "directories": {
      "output": "../release"
    }
  }
}
